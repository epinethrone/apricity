# Copy to `.env` and edit, or export these before running `python3 server.py`.

# Network
PORT=8765

# MemPalace install layout
MEMPALACE_HOME="$HOME/.mempalace"
MEMPALACE_PYTHON_BIN="$HOME/.local/share/mempalace-venv/bin/python"

# Optional: shared-secret bypass for scripted clients (sends header X-Auth-Token).
# Leave unset to rely purely on the username/password login flow.
# MEMPALACE_TOKEN=
