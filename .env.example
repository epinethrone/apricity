# MemPalace Dashboard — example environment configuration.
#
# Copy to `.env` and edit, or `export` these variables before running
# `python3 server.py`. Every variable is optional; defaults match a stock
# MemPalace install under ~/.mempalace.

# ---- Network ----------------------------------------------------------------

# Port the dashboard listens on. The server always binds to 127.0.0.1.
PORT=8765

# ---- MemPalace install layout ----------------------------------------------

# Root for all dashboard data and the palace itself.
MEMPALACE_HOME="$HOME/.mempalace"

# Python interpreter that can `import mempalace`. The dashboard shells out
# to this binary for every write — reads go straight to SQLite.
MEMPALACE_PYTHON_BIN="$HOME/.local/share/mempalace-venv/bin/python"

# ---- Storage paths (override if your MemPalace install is non-standard) ----

# The Chroma SQLite backend that stores drawer content.
# MEMPALACE_PALACE_DB="$MEMPALACE_HOME/palace/chroma.sqlite3"

# The knowledge-graph SQLite database.
# MEMPALACE_KG_DB="$MEMPALACE_HOME/knowledge_graph.sqlite3"

# Where drafts are staged before being filed into the palace.
# MEMPALACE_INBOX="$MEMPALACE_HOME/dashboard-inbox"

# Append-only log of deletes and edits — powers the "Recently deleted" view.
# MEMPALACE_VERSIONS="$MEMPALACE_HOME/dashboard-versions.jsonl"

# ---- Auth -------------------------------------------------------------------

# Username + PBKDF2-SHA256 hash. Created on first run via the Settings sheet.
# File is written with mode 0600.
# MEMPALACE_CREDENTIALS="$MEMPALACE_HOME/dashboard-credentials.json"

# Active session tokens (one per logged-in client). Mode 0600.
# MEMPALACE_SESSIONS="$MEMPALACE_HOME/dashboard-sessions.json"

# Optional shared-secret bypass for scripted clients. Send as `X-Auth-Token`.
# Coexists with the cookie flow; leave unset to require interactive login.
# MEMPALACE_TOKEN=
